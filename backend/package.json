    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "prisma": "^6.5.0",
    "typescript": "^5.7.3"
  }
}
